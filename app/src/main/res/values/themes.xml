<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PetHome" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="materialButtonStyle">@style/Widget.AppCompat.Button</item>
        <item name="android:background">#FFF3E0</item>

    </style>

    <style name="Theme.PetHome" parent="Base.Theme.PetHome" />
    <style name="text_20" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#3E2723</item>
        <item name="android:textSize"> @dimen/_20sdp</item>
        <item name="android:layout_marginTop">@dimen/_20sdp</item>
    </style>
    <style name="edit_15" parent="Widget.AppCompat.EditText">
        <item name="android:padding">@dimen/_15sdp</item>
        <item name="android:background">@color/white</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
   </style>

    <style name="button_1" >
        <item name="android:background">@drawable/custom_button</item>

        <item name="android:layout_marginTop">@dimen/_20sdp</item>
        <item name="android:padding">@dimen/_12sdp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="text_15" parent="Widget.AppCompat.TextView">
        <item name="android:layout_centerHorizontal">true</item>
        <item name="android:textColor">#3E2723</item>
        <item name="android:textSize">@dimen/_15sdp</item>
<!--        <item name="android:layout_marginTop">@dimen/_35sdp</item>-->
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="radio_15" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_15sdp</item>
    </style>
</resources>
