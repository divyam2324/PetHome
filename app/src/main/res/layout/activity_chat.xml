<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF3E0"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_64sdp"
        android:background="@android:color/transparent"
        android:paddingHorizontal="@dimen/_16sdp"
        android:elevation="@dimen/_6sdp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            android:layout_centerVertical="true"
            android:background="#FFF3E0"
            android:padding="@dimen/_6sdp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_back"
                app:tint="#3E2723" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PetCare AI"
                android:textColor="#3E2723"
                android:textSize="@dimen/_17sdp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Online"
                android:textColor="#008000"
                android:textSize="@dimen/_11sdp" />
        </LinearLayout>


    </RelativeLayout>

    <!-- Chat Area -->
    <ScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/_14sdp">

        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Date separator -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/_14sdp"
                android:background="#33BCAAA4"
                android:paddingHorizontal="@dimen/_14sdp"
                android:paddingVertical="@dimen/_4sdp"
                android:text="Today"
                android:textColor="#8D6E63"
                android:textSize="@dimen/_11sdp" />

        </LinearLayout>
    </ScrollView>


    <!-- Input Area -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_12sdp"
        android:layout_marginBottom="@dimen/_16sdp"
        android:layout_marginTop="@dimen/_6sdp"
        app:cardCornerRadius="@dimen/_28sdp"
        app:cardElevation="@dimen/_4sdp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/_16sdp"
            android:paddingEnd="@dimen/_6sdp"
            android:paddingVertical="@dimen/_6sdp">

            <EditText
                android:id="@+id/editSymptoms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Describe your pet's symptoms…"
                android:textColorHint="#BCAAA4"
                android:paddingVertical="@dimen/_10sdp"
                android:textColor="#3E2723"
                android:textSize="@dimen/_14sdp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:indeterminateTint="#D84315"
                android:visibility="gone" />

            <!-- Send button as ImageButton -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_42sdp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_message"
                android:padding="@dimen/_10sdp"
                android:scaleType="fitCenter"
                app:tint="#D84315" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>