<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp"
        android:orientation="vertical">

        <TextView
            android:text="List a Pet"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            style="@style/edit_15"
            android:id="@+id/etPetName"
            android:hint="PetName"/>

        <Spinner
            android:id="@+id/spSpecies"
            android:paddingTop="@dimen/_10sdp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <EditText
            style="@style/edit_15"
            android:id="@+id/etBreed"
            android:layout_marginTop="10dp"
            android:hint="Breed"/>

        <EditText
            style="@style/edit_15"
            android:id="@+id/etAge"
            android:hint="Age"
            android:inputType="number"
            android:layout_marginTop="10dp" />

        <RadioGroup
            android:id="@+id/rgGender"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/_10sdp"
                android:text="Male"/>

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female"/>
        </RadioGroup>

        <CheckBox
            android:id="@+id/cbChildren"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good with children?"/>

        <CheckBox
            android:id="@+id/cbOtherPets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good with other pets?"/>

        <!-- 🔥 IMAGE SECTION -->

        <ImageView
            android:id="@+id/imgPet"
            android:layout_width="@dimen/_100sdp"
            android:layout_height="@dimen/_100sdp"
            android:layout_marginTop="15dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"/>

        <Button
            android:id="@+id/btnSelectImage"
            style="@style/button_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Pet Image"
            android:layout_marginTop="5dp"/>

        <EditText
            style="@style/edit_15"
            android:id="@+id/etContactName"
            android:hint="Contact Name"
            android:layout_marginTop="10dp" />

        <EditText
            style="@style/edit_15"
            android:id="@+id/etContactInfo"
            android:hint="Phone / Email"
            android:inputType="number"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnSubmit"
            style="@style/button_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="15dp"/>



    </LinearLayout>

</ScrollView>