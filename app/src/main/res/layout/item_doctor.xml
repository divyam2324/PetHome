<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_8sdp"
    app:cardCornerRadius="@dimen/_12sdp"
    app:cardElevation="@dimen/_2sdp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/_12sdp">

        <ImageView
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:src="@drawable/ic_profile"
            app:tint="#2E7D32" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/_12sdp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Name"
                android:textColor="#333333"
                android:textSize="@dimen/_14sdp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vet Surgeon"
                android:textColor="#2E7D32"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtExperience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5+ Years Experience"
                android:textColor="#666666"
                android:textSize="@dimen/_10sdp" />

            <TextView
                android:id="@+id/txtContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: 1234567890"
                android:textColor="#666666"
                android:textSize="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_4sdp"/>

            <TextView
                android:id="@+id/txtShelterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shelter: PetHome Shelter"
                android:textColor="#D84315"
                android:textSize="@dimen/_10sdp"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/_2sdp"
                android:visibility="gone"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnDeleteDoctor"
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_close"
           />

    </LinearLayout>
</androidx.cardview.widget.CardView>
