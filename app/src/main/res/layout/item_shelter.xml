<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_8sdp"
    app:cardCornerRadius="@dimen/_12sdp"
    app:cardElevation="@dimen/_2sdp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_12sdp">

        <TextView
            android:id="@+id/txtShelterName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shelter Name"
            android:textColor="#2E7D32"
            android:textSize="@dimen/_14sdp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtShelterCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City: New York"
            android:textColor="#666666"
            android:textSize="@dimen/_11sdp" />

        <TextView
            android:id="@+id/txtShelterContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact: 1234567890"
            android:textColor="#666666"
            android:textSize="@dimen/_11sdp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="@dimen/_8sdp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical Facilities:"
            android:textColor="#333333"
            android:textSize="@dimen/_10sdp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMedicalInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No medical information provided."
            android:textColor="#666666"
            android:textSize="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_2sdp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
