<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF6EC">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_20sdp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtWelcome"
            android:layout_weight="1"
            style="@style/text_20"
            android:layout_marginTop="@dimen/_5sdp"
            android:text="Welcome, User!"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:src="@drawable/ic_profile"/>
    </LinearLayout>

    <!-- Search Bar -->

    <androidx.cardview.widget.CardView
        app:cardElevation="@dimen/_5sdp"
        android:id="@+id/searchCard"
        android:layout_below="@+id/headerLayout"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        app:cardCornerRadius="@dimen/_5sdp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:id="@+id/etSearch"
            style="@style/edit_15"
            android:hint="Search pets..."/>


    </androidx.cardview.widget.CardView>
    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/actionLayout"
        android:layout_below="@id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdopt"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/_100sdp"
                android:layout_margin="@dimen/_8sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_6sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Adopt a Pet"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardList"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/_100sdp"
                android:layout_margin="@dimen/_8sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_6sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="List Your Pet"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardRequests"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/_100sdp"
                android:layout_margin="@dimen/_8sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_6sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="My Requests"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardFavorites"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/_100sdp"
                android:layout_margin="@dimen/_8sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_6sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Favorites"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Featured Pets RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFeatured"
        android:layout_below="@id/actionLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_200sdp"
        android:layout_margin="@dimen/_16sdp"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_72sdp"
        android:layout_alignParentBottom="true"
        android:elevation="@dimen/_12sdp"
        app:itemIconSize="28dp"
        app:itemTextAppearanceActive="@style/BottomNavText"
        app:itemTextAppearanceInactive="@style/BottomNavText"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_menu" />
</RelativeLayout>