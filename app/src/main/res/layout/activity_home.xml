<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FFDDA9">

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_62sdp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="@dimen/_10sdp"
        app:itemIconSize="@dimen/_22sdp"
        app:itemIconTint="@drawable/bottom_nav_selector"
        app:itemTextColor="@drawable/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_menu" />

    <!-- Chat Bot FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPetCare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomNav"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="@dimen/_16sdp"
        android:layout_marginBottom="@dimen/_16sdp"
        android:src="@drawable/ic_bot"
        android:contentDescription="PetCare ChatBot"
        app:backgroundTint="#D84315"
        app:tint="#FFFFFF"
        app:elevation="@dimen/_6sdp" />

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_60sdp"
                android:background="#FFDDA9"
                android:paddingHorizontal="@dimen/_18sdp">

                <LinearLayout
                    android:layout_centerInParent="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#FFDDA9"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PetHome"
                        android:textColor="#3E2723"
                        android:background="#FFDDA9"
                        android:textSize="@dimen/_17sdp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnProfile"
                    android:layout_width="@dimen/_34sdp"
                    android:layout_height="@dimen/_34sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="@dimen/_17sdp"
                    app:cardBackgroundColor="#FFB74D">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="#3E2723"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <!-- Hero Banner -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_152sdp"
                android:background="#FFDDA9">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerVertical="true"
                    android:background="#FFDDA9"
                    android:layout_marginStart="@dimen/_20sdp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning 🌤"
                        android:textColor="#3E2723"
                        android:background="#FFDDA9"
                        android:textSize="@dimen/_12sdp" />
                    <TextView
                        android:id="@+id/txtWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome!"
                        android:textColor="#3E2723"
                        android:background="#FFDDA9"
                        android:textStyle="bold"
                        android:textSize="@dimen/_20sdp" />
                    <TextView
                        android:id="@+id/heroCta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  Browse Pets →  "
                        android:textColor="#3E2723"
                        android:textStyle="bold"
                        android:background="@drawable/chip_honey"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:paddingVertical="@dimen/_6sdp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="@dimen/_130sdp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/icon_1"
                    android:scaleType="fitCenter"
                    android:background="#FFDDA9"
                    android:alpha="0.88" />
            </RelativeLayout>

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textColor="#3E2723"
                android:textStyle="bold"
                android:textSize="@dimen/_15sdp"
                android:layout_marginHorizontal="@dimen/_18sdp"
                android:layout_marginTop="@dimen/_18sdp" />

            <!-- Quick Action Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingTop="@dimen/_12sdp">
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardListPet"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_add" app:tint="#E64A19" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="List Pet" android:textColor="#3E2723" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAdopt"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_pets" app:tint="#FFB74D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Adopt" android:textColor="#3E2723" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMyRequests"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_inbox" app:tint="#E64A19" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MyRequests" android:textColor="#3E2723" android:textStyle="bold" />
                        <TextView android:id="@+id/txtMyRequestsCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 pending" android:textColor="#8D6E63" android:textSize="@dimen/_9sdp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_12sdp"
                android:paddingBottom="@dimen/_12sdp">
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardShelters"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_location" app:tint="#FFB74D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shelters" android:textColor="#3E2723" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFavorites"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_favorite" app:tint="#E64A19" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Favorites" android:textColor="#3E2723" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHistory"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/_92sdp"
                    android:layout_margin="@dimen/_5sdp"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView android:layout_width="@dimen/_28sdp" android:layout_height="@dimen/_28sdp" android:src="@drawable/ic_history" app:tint="#FFB74D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textColor="#3E2723" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Pets Near You -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_18sdp"
                android:layout_marginTop="@dimen/_18sdp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Pets Near You"
                    android:textColor="#3E2723"
                    android:textStyle="bold"
                    android:textSize="@dimen/_15sdp" />
                <TextView
                    android:id="@+id/btnSeeAllPets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all →"
                    android:textColor="#D84315"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNearbyPets"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_200sdp"
                android:paddingHorizontal="@dimen/_12sdp"
                android:clipToPadding="false" />

            <!-- Available Doctors Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Doctors"
                android:textColor="#3E2723"
                android:textStyle="bold"
                android:textSize="@dimen/_15sdp"
                android:layout_marginHorizontal="@dimen/_18sdp"
                android:layout_marginTop="@dimen/_18sdp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHomeDoctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/_12sdp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="@dimen/_8sdp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_24sdp" />

        </LinearLayout>
    </ScrollView>

    <!-- Invisible placeholder for btnSeeAllRequests -->
    <View android:id="@+id/btnSeeAllRequests" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" />

</RelativeLayout>
