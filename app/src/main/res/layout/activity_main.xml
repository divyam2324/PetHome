<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/main_img"
        android:layout_width="@dimen/_150sdp"
        android:layout_height="@dimen/_150sdp"
        android:layout_centerHorizontal="true"
        android:src="@drawable/icon_1"
        android:layout_marginTop="@dimen/_30sdp"
        />

    <TextView
        style="@style/text_20"
        android:id="@+id/main_title"
        android:layout_below="@+id/main_img"
        android:text="Login to your Account"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"/>

    <androidx.cardview.widget.CardView
        app:cardElevation="@dimen/_5sdp"
        android:id="@+id/main_email_card"
        android:layout_below="@+id/main_title"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        app:cardCornerRadius="@dimen/_5sdp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            style="@style/edit_15"
            android:id="@+id/main_email"
            android:inputType="textEmailAddress"
            android:hint="Email"/>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/main_password_card"
        android:layout_below="@+id/main_email_card"
        android:layout_marginTop="@dimen/_15sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        app:cardElevation="@dimen/_5sdp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            style="@style/edit_15"
            android:id="@+id/main_password"
            android:inputType="textPassword"
            android:hint="Password"/>

    </androidx.cardview.widget.CardView>

    <Button
        style="@style/button_1"
        android:id="@+id/login_btn"
        android:layout_below="@+id/main_password_card"
        android:text="Sign in"
        android:textColor="#3E2723"
        android:textSize="@dimen/_12sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
      />


    <TextView
        style="@style/text_15"
        android:id="@+id/main_signin_with"
        android:layout_below="@+id/login_btn"
        android:layout_marginTop="@dimen/_35sdp"

        android:text="- Or sign in with -"
       />
    
    <LinearLayout
        android:id="@+id/main_socialmedia"
        android:layout_below="@+id/main_signin_with"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            style="@style/img_bg"

            android:layout_margin="@dimen/_5sdp"
            app:cardElevation="@dimen/_3sdp"
            android:layout_weight="1"
            app:cardCornerRadius="@dimen/_10sdp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_55sdp">

            <ImageView
                android:layout_gravity="center"
                android:src="@drawable/google"
                android:background="@color/white"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_45sdp"/>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_margin="@dimen/_5sdp"
            app:cardElevation="@dimen/_3sdp"
            android:layout_weight="1"
            app:cardCornerRadius="@dimen/_10sdp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_55sdp">

            <ImageView
                android:layout_gravity="center"
                android:src="@drawable/facebook"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_45sdp"/>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_margin="@dimen/_5sdp"
            app:cardElevation="@dimen/_3sdp"
            android:layout_weight="1"
            app:cardCornerRadius="@dimen/_10sdp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_55sdp">

            <ImageView
                android:layout_gravity="center"
                android:src="@drawable/twitter"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="@dimen/_45sdp"/>

        </androidx.cardview.widget.CardView>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/login_redirect"
        android:layout_marginTop="@dimen/_30sdp"
        android:layout_marginHorizontal="@dimen/_20sdp"
        android:layout_below="@id/main_socialmedia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <TextView
            style="@style/text_15"
            android:text="Don't have an account? "/>
        <TextView
            android:id="@+id/main_signup"
            style="@style/text_15"
            android:text="Sign up"
            android:textStyle="bold"/>
    </LinearLayout>

</RelativeLayout>